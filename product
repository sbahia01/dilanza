<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DILANZA | Detalhes do Produto</title>
    <link rel="stylesheet" href="style.css">
</head>
<body onload="loadProductDetails()">
    <header>
        <div class="lang-selector">
            <button id="btnPT" class="lang-btn active">PT</button>
            <button id="btnEN" class="lang-btn">EN</button>
        </div>
        <h1 onclick="window.location.href='index.html'" style="cursor:pointer">DILANZA</h1>
    </header>

    <main class="product-page-container">
        <div class="product-image-side">
            <img id="mainProductImage" src="" alt="Produto">
        </div>

        <div class="product-info-side">
            <nav class="breadcrumb">Página Inicial > Camisetas > <span id="breadName"></span></nav>
            <h2 id="productTitle"></h2>
            <p id="productPrice" class="price-large"></p>

            <div class="size-selector">
                <span>Selecione o tamanho:</span>
                <div class="size-options">
                    <button>P</button><button>M</button><button>G</button><button>GG</button>
                </div>
            </div>

            <button class="buy-btn-large">ADICIONAR AO CARRINHO</button>

            <div class="shipping-info">
                <p><strong>Previsão de entrega:</strong> 2 a 5 dias úteis</p>
                <p class="return-policy">Devoluções gratuitas em até 30 dias.</p>
            </div>

            <div class="product-specs">
                <h3>OS DETALHES</h3>
                <ul id="specList">
                    <li>Algodão Pima 100%</li>
                    <li>Gola careca</li>
                    <li>Manga Curta</li>
                    <li>Toque Macio</li>
                </ul>
            </div>
        </div>
    </main>

    <script>
        // Lógica para carregar o produto correto nesta página
        function loadProductDetails() {
            const product = localStorage.getItem('selectedProduct') || 'black';
            const img = document.getElementById('mainProductImage');
            const title = document.getElementById('productTitle');
            const bread = document.getElementById('breadName');
            const price = document.getElementById('productPrice');

            if(product === 'black') {
                img.src = 'camisa-preta.webp';
                title.innerText = 'CAMISA PIMA - PRETA';
                bread.innerText = 'Preta';
                price.innerText = 'R$ 490,00';
            } else {
                img.src = 'camisa-branca.webp';
                title.innerText = 'CAMISA PIMA - BRANCA';
                bread.innerText = 'Branca';
                price.innerText = 'R$ 490,00';
            }
        }
    </script>
</body>
</html>
